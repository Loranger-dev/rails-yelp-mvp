<h1 class="mb-4" >Restaurants</h1>

<ul class="list-group" >
  <% @restaurants.each do |restaurant| %>
  <li class="list-group-item d-flex justify-content-between align-items_center" >
    <div>
    <%= link_to restaurant.name, restaurant_path(restaurant) %>
     - <%= restaurant.address %>
     - <%= restaurant.category %>
    </div>
    <%= link_to "See details", restaurant_path(restaurant), class: "btn btn-primary" %>
  </li>

  <% end %>

</ul>
