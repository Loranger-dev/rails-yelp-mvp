<h1><%= @restaurant.name %></h1>
<p><strong>Address : </strong><%= @restaurant.address %></p>
<p><strong>Phone number : </strong><%= @restaurant.phone_number %></p>
<p><strong>Category : </strong><%= @restaurant.category %></p>

<hr>

<h2>Reviews</h2>
<ul>
  <strong><% @restaurant.reviews.each do |review| %></strong>
  <li>
    <strong><%= review.rating  %>/5</strong> - <%= review.content %>
  </li>
  <% end %>
</ul>
<hr>

<h2>Add a review</h2>

  <%= simple_form_for [@restaurant, @review] do |f| %>
    <%= f.input :content %>
    <%= f.input :rating, collection: 0..5 %>
    <%= f.submit "Create review", class: "btn btn-primary" %>
  <% end %>

<%= link_to "Back to restaurants", restaurants_path, class: "btn btn-secondary" %>
